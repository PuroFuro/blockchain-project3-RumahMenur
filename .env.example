# Copy to .env and fill in ONLY if deploying to Sepolia (optional bonus).
# Local development never needs these. NEVER commit the real .env.

# An RPC endpoint for Sepolia (e.g. from Alchemy or Infura).
SEPOLIA_RPC_URL=

# A funded test-account private key. Use a throwaway account, never a real one.
PRIVATE_KEY=
